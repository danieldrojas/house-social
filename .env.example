# Local SQLite (default for development)
DATABASE_URL="file:./dev.db"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Optional: only needed for some local auth setups
# AUTH_URL="http://localhost:3000"

# Production (Vercel): use a hosted Postgres URL instead, e.g. Neon
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Production photos (Vercel Blob) — without this, images save to public/uploads (local only)
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
